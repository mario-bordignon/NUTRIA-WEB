---
import CardPlanos from '../components/CardPlanos.astro';
---

<!--
==========================================================
   CABEÇALHO (metatags, título da página, favicon e CSS)
==========================================================
-->
<!--#region-->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nutria</title>

    <link rel="icon" type="image/svg+xml" href="img/favicon.svg">

    <link is:inline rel="stylesheet" href="css/main.css">
    <link is:inline rel="stylesheet" href="css/navbar.css">
    <link is:inline rel="stylesheet" href="css/hero.css">
    <link is:inline rel="stylesheet" href="css/features.css">
    <link is:inline rel="stylesheet" href="css/banner.css">
    <link is:inline rel="stylesheet" href="css/carousel.css">
    <link is:inline rel="stylesheet" href="css/plans.css">
    <link is:inline rel="stylesheet" href="css/team.css">
    <link is:inline rel="stylesheet" href="css/components.css">
</head>
<!--#endregion-->

<body>
<!--
===================================================
   NAVBAR (logo, navlinks, troca tema e download)
===================================================
-->
<!--#region-->
    <nav class="navbar">
        <div class="nav-container">
            
            <div class="logo">
                <a href="index.html">
                     <img src="img/N-logo.svg" alt="Logo Nutria">
                </a>
            </div>
            
            <ul class="nav-links">
                <li><a href="#funcoes">Funções</a></li>
                <li><a href="#planos">Planos</a></li>
                <li><a href="#equipe">Equipe</a></li>
                <li><a href="#sobre">Sobre</a></li>
            </ul>

            <div class="nav-actions">
                <button id="themeToggle" class="btn-theme" aria-label="Alternar Tema">
                    <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                    </svg>
                    <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="5"></circle>
                        <line x1="12" y1="1" x2="12" y2="3"></line>
                        <line x1="12" y1="21" x2="12" y2="23"></line>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                        <line x1="1" y1="12" x2="3" y2="12"></line>
                        <line x1="21" y1="12" x2="23" y2="12"></line>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                    </svg>
                </button>
                <button class="btn-download download-trigger">Baixe agora</button>
            </div>
            
        </div>
    </nav>
<!--#endregion-->





<!--
=====================================
   HERO (título, download e termos)
=====================================
-->
<!--#region-->
    <main class="main-content">
        
        <section class="hero">
            <h1 class="hero-title">
                Mantenha e compartilhe<br>uma alimentação saudável
            </h1>
            <p class="hero-subtitle">
                Encontre uma comunidade e desenvolva<br>sua rotina com saúde e motivação
            </p>
            <div class="hero-actions">
                <button class="hero-btn download-trigger">Baixe agora (00 MB)</button>
                <p class="hero-terms">
                    Ao baixar, você concorda com nossos <a href="termos.pdf" target="_blank">termos e condições</a>
                </p>
            </div>
        </section>
<!--#endregion-->





<!--
============================================
   FEATURES (benefícios em lista e imagem)
============================================
--> 
<!--#region-->
        <section class="features" id="sobre">
            <div class="features-wrapper">
                <div class="features-text">
                    <h2 class="features-title">
                        O ambiente digital perfeito<br>para a sua alimentação
                    </h2>
                    <ul class="features-list">
                        <li>Poste suas receitas e dietas</li>
                        <li>Rotinas personalizadas para seu objetivo</li>
                        <li>Trilhe sozinho ou em grupos</li>
                        <li>Motive-se com nosso sistema de ofensiva</li>
                    </ul>
                    <h3 class="features-subtitle">
                        Tudo que você precisa, um só lugar.
                    </h3>
                </div>
                <div class="features-image">
                    <img src="img/celular.svg" alt="Aplicativo Nutria no Celular">
                </div>
            </div>
        </section>
<!--#endregion-->





<!--
=======================================
   FAIXA/BANNER (banner preto visual)
=======================================
-->
<!--#region-->
        <section class="black-banner">
            <h2 class="banner-title">
                O aplicativo ideal para quem<br>busca novos começos.
            </h2>
        </section>
        
    </main>
<!--#endregion-->





<!--
=====================================
   PLANOS (assinaturas + carrossel)
=====================================
-->
<!--#region-->
    <div class="plans-container">
    
    <CardPlanos nomeDoPlano="Básico">
        <div slot="icone">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </div>
        <div slot="features">
            <li><svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Limite de 4 postagens</li>
            <li><svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Limite de 1 grupo</li>
            <li class="disabled-feature"><svg class="cross-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>Análise de macros com IA</li>
        </div>
    </CardPlanos>

    <CardPlanos nomeDoPlano="Premium" classeDestaque="premium">
        <div slot="icone">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </div>
        <div slot="features">
            </div>
    </CardPlanos>

</div>
<!--#endregion-->





<!--
=====================================
   NOSSA EQUIPE (fotos + carrossel)
=====================================
-->
<!--#region-->
    <section class="team" id="equipe">
        <h2 class="team-title">Nossa Equipe</h2>
        <div class="carousel-wrapper">
            
            <button class="carousel-btn prev" id="teamPrev" aria-label="Anterior">‹</button>
            
            <div class="carousel-viewport" id="teamViewport">
                <div class="team-container">
                    
                    <div class="team-member"><img src="img/matheus.png" alt="Matheus" class="team-photo"></div>
                    <div class="team-member"><img src="img/diego.png" alt="Diego" class="team-photo"></div>
                    <div class="team-member"><img src="img/dominique.png" alt="Dominique" class="team-photo"></div>
                    <div class="team-member"><img src="img/mario.png" alt="Mario" class="team-photo"></div>
                    <div class="team-member"><img src="img/chantal.png" alt="Chantal" class="team-photo"></div>
                
                    <div class="team-member logo-filler">
                        <img src="img/favicon.svg" class="team-photo filler-img" alt="Logo Nutria">
                    </div>
                    
                </div>
            </div>
            
            <button class="carousel-btn next" id="teamNext" aria-label="Próximo">›</button>
            
        </div>
    </section>
<!--#endregion-->





<!--
=================================================
   UTILITÁRIOS E MODAL (botão de topo e modais)
=================================================
-->
<!--#region-->
    <button id="btnScrollTop" class="btn-scroll-top" aria-label="Voltar ao topo">
        <svg width="26" height="22" viewBox="0 0 24 24" fill="#D1D5DB" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 4L24 20H0L12 4Z" />
        </svg>
    </button>

    <div id="qrModal" class="modal-overlay">
        <div class="modal-content">
            <button id="closeModal" class="btn-close-modal" aria-label="Fechar">&times;</button>
            <h3 class="modal-title">Baixe no seu celular</h3>
            <p class="modal-text">Escaneie o QR Code abaixo para iniciar o download do Nutria em seu celular.</p>
            <div class="qr-placeholder">
                <img src="img/qrcode.png" alt="QR Code para download do APK" id="qrImage">
            </div>
        </div>
    </div>

    <div id="iosModal" class="modal-overlay">
        <div class="modal-content">
            <button id="closeIosModal" class="btn-close-modal" aria-label="Fechar">&times;</button>
            <h3 class="modal-title">Sentimos Muito :(</h3>
            <p class="modal-text">No momento, o aplicativo Nutria está disponível apenas para dispositivos Android.</p>
        </div>
    </div>
<!--#endregion-->





<!--
========================================
   SCRIPTS (importação dos javascripts)
========================================
-->
<!--#region-->
    <script is:inline src="/js/theme.js"></script>
	<script is:inline src="/js/scrollTop.js"></script>
	<script is:inline src="/js/downloadModals.js"></script>
	<script is:inline src="/js/carouselPlans.js"></script>
	<script is:inline src="/js/carouselTeam.js"></script>
<!--#endregion-->

</body>
</html>